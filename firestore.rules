rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Cattle collection — allow all reads; allow writes for authenticated users or guest sessions
    // NOTE: For production, tighten to: request.auth != null
    match /cattle/{cattleId} {
      allow read: if true;
      allow write: if true;
    }

    // Ledger — immutable audit trail, append-only
    match /ledger/{entryId} {
      allow read: if true;
      allow create: if true;
      // Prevent editing or deleting ledger entries (immutability)
      allow update, delete: if false;
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
